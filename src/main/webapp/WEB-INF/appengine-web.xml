<?xml version="1.0" encoding="UTF-8"?>

<appengine-web-app xmlns="http://appengine.google.com/ns/1.0">

  <runtime>java17</runtime>
  <app-engine-apis>true</app-engine-apis>
  <automatic-scaling>
    <max-instances>1</max-instances>
  </automatic-scaling>
  <sessions-enabled>false</sessions-enabled>
  <version>GCLOUD_CONFIG</version>

  <!-- Configure java.util.logging -->
  <system-properties>
    <property name="appengine.use.EE8" value="true"/>
    <property name="java.util.logging.config.file" value="WEB-INF/logging.properties"/>
  </system-properties>

  <!-- Resource file directory -->
  <resource-files>
    <include path="WEB-INF/StaticFiles/*"/>
  </resource-files> 
  
  <!-- Static Files -->    
  <static-files>
    <include path="index.html" />
    <include path="favicon.ico" />
    <include path="kerguelenpetrel.png" />
  </static-files>
  
<!-- Replace these with your keys:
MASTODON_INSTANCE_URL=your-mastodon-instance
MASTODON_ACCESS_TOKEN=YOUR_MASTODON_ACCESS_TOKEN
WORDNIK_API_KEY=your-api-key
-->

  <!-- Fix Unknown Host error when using ROME -->
  <url-stream-handler>urlfetch</url-stream-handler>
  
</appengine-web-app>