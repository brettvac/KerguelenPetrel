<?xml version="1.0" encoding="UTF-8"?>
<web-app 
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
   xmlns="http://java.sun.com/xml/ns/javaee" 
   xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd" 
   version="2.5">
   
   <servlet>
    <servlet-name>KerguelenpetrelServlet</servlet-name>
    <servlet-class>io.github.brettvac.kerguelenpetrel.KerguelenpetrelServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>KerguelenpetrelServlet</servlet-name>
    <url-pattern>/KerguelenpetrelServlet</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>UpdateStatusServlet</servlet-name>
    <servlet-class>io.github.brettvac.kerguelenpetrel.UpdateStatusServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UpdateStatusServlet</servlet-name>
    <url-pattern>/cron/UpdateStatusServlet</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>BotherSomeoneServlet</servlet-name>
    <servlet-class>io.github.brettvac.kerguelenpetrel.BotherSomeoneServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>BotherSomeoneServlet</servlet-name>
    <url-pattern>/cron/BotherSomeoneServlet</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>RespondServlet</servlet-name>
    <servlet-class>io.github.brettvac.kerguelenpetrel.RespondServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>RespondServlet</servlet-name>
    <url-pattern>/cron/RespondServlet</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>FriendSomeoneServlet</servlet-name>
    <servlet-class>io.github.brettvac.kerguelenpetrel.FriendSomeoneServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>FriendSomeoneServlet</servlet-name>
    <url-pattern>/cron/FriendSomeoneServlet</url-pattern>
  </servlet-mapping>
  
  <servlet>
    <servlet-name>UnfriendSomeoneServlet</servlet-name>
    <servlet-class>io.github.brettvac.kerguelenpetrel.UnfriendSomeoneServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>UnfriendSomeoneServlet</servlet-name>
    <url-pattern>/cron/UnfriendSomeoneServlet</url-pattern>
  </servlet-mapping>
  
  <security-constraint>
    <web-resource-collection>
      <web-resource-name>CronTasks</web-resource-name>
      <url-pattern>/cron/*</url-pattern>
    </web-resource-collection>
    <user-data-constraint>
      <transport-guarantee>CONFIDENTIAL</transport-guarantee> 
    </user-data-constraint>
    <auth-constraint>
      <role-name>admin</role-name> 
    </auth-constraint>
  </security-constraint>
  
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>
</web-app>